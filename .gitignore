# Secrets — never commit these
.env
.env.*
!.env.example

# .aio contains client_secrets — each dev downloads their own
.aio

# Dependencies
node_modules/
**/node_modules/

# Local dev storage (in-memory adapter dumps)
**/local-storage/

# OAuth token cache (auto-managed by services/oauth.js)
**/.tokens/

# Build output
dist/
build/
.parcel-cache/

# Logs
logs/*
!logs/.gitkeep
*.log
npm-debug.log*

# App Builder
dist-app/
web-dist/
web-dev/

# Legacy POC — not part of new platform
apps/catch/
apps/aics-lab-console-develop/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Test artifacts
coverage/
screenshots/
*.db

# QA workflow reports (playwright-validator + agent-browser output)
.qa-reports/
.claude/data/claude-model-cache
.claude/data/sessions
**/.claude/data/sessions/
**/.playwright-mcp/

# ADW — runtime artifacts (never commit)
agents/*
!agents/.gitkeep
trees/*
!trees/.gitkeep
adws/trees/
adws/agents/
adws/logs/
adws/__pycache__/
adws/adw_modules/__pycache__/
adws/adw_triggers/__pycache__/
adws/.env.adw

# Generated files that cause rebase conflicts across branches
.ports.env
**/__pycache__/
*.pyc
apps/spectrum-init
