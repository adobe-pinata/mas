# Secrets — never commit these
.env
.env.*
!.env.example

# .aio contains client_secrets — each dev downloads their own
.aio

# Dependencies
node_modules/
**/node_modules/

# Local dev storage (in-memory adapter dumps)
**/local-storage/

# OAuth token cache (auto-managed by services/oauth.js)
**/.tokens/

# Build output
dist/
build/
.parcel-cache/

# Logs
*.log
logs/*
!logs/.gitkeep
.logs/

# App Builder
dist-app/
web-dist/
web-dev/

# App layer — each app has its own git repo
apps/*
!apps/.gitkeep

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Test artifacts
coverage/
screenshots/
*.db

# QA workflow reports (playwright-validator + agent-browser output)
.qa-reports/
.reports/
.claude/data/claude-model-cache
.claude/data/sessions
**/.claude/data/sessions/
**/.playwright-mcp/

# ADW — runtime artifacts (never commit)
agents/*
!agents/.gitkeep
trees/*
!trees/.gitkeep
adws/trees/
adws/agents/
adws/logs/
adws/__pycache__/
adws/adw_modules/__pycache__/
adws/adw_triggers/__pycache__/
adws/.env.adw

# Generated files that cause rebase conflicts across branches
.ports.env
**/__pycache__/
*.pyc
