# ============================================================================
# Agentic Layer — operator config for ADW system
# ============================================================================
GITHUB_PAT=
# GitHub App (bot identity for ADWS posts — posts as app-name[bot])
# Create at: https://github.com/settings/apps
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PEM_PATH=
CLAUDE_CODE_PATH=/Users/rivero/.local/bin/claude
# ============================================================================
# Adobe I/O Runtime — Adobe Corp / Adobe Experience QA / dev workspace
AIO_runtime_auth=
AIO_runtime_namespace=
AIO_runtime_apihost=https://adobeioruntime.net
AIO_CONSOLE_PROJECT_ID=
AIO_CONSOLE_WORKSPACE_ID=
# Anthropic (REQUIRED for local dev — fill this in)
CLAUDE_CODE_OAUTH_TOKEN=
# App Config
NODE_ENV=development
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
RUNNER_MODE=sequential
INTERNAL_CALLBACK_SECRET=
# Integrations — optional for Phase 1
JIRA_BASE_URL=
JIRA_TOKEN=
JIRA_PROJECT_KEY=
SLACK_WEBHOOK_URL=
# Slack Inbound Trigger — Socket Mode (no public endpoint needed)
# Setup: https://api.slack.com/apps → Create App → Enable Socket Mode
#   1. Enable Socket Mode → generates SLACK_APP_TOKEN (xapp-...)
#   2. Add Bot Token Scopes: channels:history, channels:read, chat:write
#   3. Subscribe to Events: message.channels
#   4. Install to workspace → copy SLACK_BOT_TOKEN (xoxb-...)
#   5. Invite the bot to the target channel
#   6. Get SLACK_CHANNEL_ID from channel details in Slack (right-click channel → View channel details)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=
# Adobe I/O Events — Phase 3
AIO_EVENTS_ORGANIZATION_ID=
AIO_EVENTS_WEBHOOK_SECRET=
AIO_ims_contexts_Credential__in__Adobe__Experience__QA__-__Stage_client__id=
AIO_ims_contexts_Credential__in__Adobe__Experience__QA__-__Stage_client__secrets=
AIO_ims_contexts_Credential__in__Adobe__Experience__QA__-__Stage_technical__account__email=
AIO_ims_contexts_Credential__in__Adobe__Experience__QA__-__Stage_technical__account__id=
AIO_ims_contexts_Credential__in__Adobe__Experience__QA__-__Stage_scopes=
AIO_ims_contexts_Credential__in__Adobe__Experience__QA__-__Stage_ims__org__id=
SERVICE_API_KEY=
IMS_OAUTH_S2S_CLIENT_ID=
IMS_OAUTH_S2S_CLIENT_SECRET=
IMS_OAUTH_S2S_ORG_ID=
IMS_OAUTH_S2S_SCOPES=


# Cloudflare R2 (screenshot uploads for GitHub issue comments)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=agentic-engineering
CLOUDFLARE_R2_PUBLIC_DOMAIN=

# Observability
# CLAUDE_PROJECT_DIR is auto-set by Claude Code at runtime, but must also be present
# in .env so that hook commands (uv run $CLAUDE_PROJECT_DIR/.claude/hooks/...) resolve
# correctly before a session is fully initialized. Set to your local checkout path.
CLAUDE_PROJECT_DIR=/path/to/agentic-harness
# SOURCE_APP tags every hook event sent via send_event.py and logged to .logs/.
# Required for remote event shipping — leave blank to disable send_event.py tagging.
# Per-app overrides go in apps/{APP}/.adw.config.json (source_app or name key).
SOURCE_APP=agentic-harness
