{"timestamp":1774455750132,"source_app":"agentic-harness","session_id":"b77f2ef9-c6c1-4cc3-be9d-bcdb16bc541a","hook_event_type":"PreToolUse","tool_name":"Write","tool_use_id":"toolu_01BNKGhSkMryiuXBird5Nww6","payload":{"session_id":"b77f2ef9-c6c1-4cc3-be9d-bcdb16bc541a","transcript_path":"/Users/auto/.claude/projects/-Users-auto-agentic-harness-apps-mas-trees-93056489/b77f2ef9-c6c1-4cc3-be9d-bcdb16bc541a.jsonl","cwd":"/Users/auto/agentic-harness/apps/mas/trees/93056489","permission_mode":"bypassPermissions","hook_event_name":"PreToolUse","tool_name":"Write","tool_input":{"file_path":"/Users/auto/agentic-harness/apps/mas/trees/93056489/scripts/start_dev.sh","content":"#!/usr/bin/env bash\n# Start MAS dev servers for isolated ADW execution.\n# Reads BACKEND_PORT and FRONTEND_PORT from environment (set by adw_test_iso.py).\n# Writes PIDs to .dev_server.pids for clean shutdown.\n\nset -euo pipefail\n\nWORKTREE_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\"\nPIDS_FILE=\"$WORKTREE_DIR/.dev_server.pids\"\nBACKEND_PORT=\"${BACKEND_PORT:-8080}\"\nFRONTEND_PORT=\"${FRONTEND_PORT:-3000}\"\n\necho \"Starting MAS dev servers: backend=$BACKEND_PORT frontend=$FRONTEND_PORT\"\n\n# Start backend (studio / AEM content server)\naem up --port \"$BACKEND_PORT\" --no-open &\nBACKEND_PID=$!\n\n# Start frontend (web-components dev server)\naem up --port \"$FRONTEND_PORT\" --no-open &\nFRONTEND_PID=$!\n\n# Write PIDs for later cleanup\necho \"$BACKEND_PID $FRONTEND_PID\" > \"$PIDS_FILE\"\necho \"PIDs written: backend=$BACKEND_PID frontend=$FRONTEND_PID\"\n\n# Wait for servers to be ready (up to 30s each)\nfor PORT in \"$BACKEND_PORT\" \"$FRONTEND_PORT\"; do\n  echo \"Waiting for port $PORT...\"\n  for i in $(seq 1 30); do\n    if curl -s --max-time 1 \"http://localhost:$PORT\" >/dev/null 2>&1; then\n      echo \"  Port $PORT ready\"\n      break\n    fi\n    sleep 1\n    if [ \"$i\" -eq 30 ]; then\n      echo \"  WARNING: Port $PORT not ready after 30s, continuing anyway\"\n    fi\n  done\ndone\n\necho \"Dev servers started successfully\"\n"},"tool_use_id":"toolu_01BNKGhSkMryiuXBird5Nww6"}}
